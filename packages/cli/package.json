{
  "name": "@scope-pm/cli",
  "version": "0.1.2",
  "description": "ScopePM CLI — manage project scope via the hosted REST API.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "scope": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AICodingGuy/ScopePM-Public-Packages.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "scope",
    "cli",
    "project-management",
    "scope-pm"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "BUSL-1.1"
}
