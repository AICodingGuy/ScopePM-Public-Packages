{
  "name": "@scope-pm/mcp",
  "version": "0.1.6",
  "description": "ScopePM MCP proxy for routing MCP tool calls to the hosted API.",
  "type": "module",
  "bin": {
    "scope-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/AICodingGuy/ScopePM-Public-Packages.git",
    "directory": "packages/mcp"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "mcp",
    "scopepm",
    "project-management",
    "ai-agent",
    "coding-assistant"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
